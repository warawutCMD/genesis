{
  "compilerOptions": {
    "target": "ES2023",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "rootDir": "src",
    "outDir": "dist",

    "sourceMap": true
  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}